{% liquid

  capture nav_content
    content_for 'blocks'
  endcapture
  
%}

{% render 'block-navigation', block: block, content: nav_content, class_name: class_name %}

{% schema %}
{
  "name": "Navigation",
  "tag": null,
  "settings": [
    {
      "type": "link_list",
      "label": "Navigation Menu",
      "id": "nav"
    },
    {
      "type": "select",
      "label": "Navigation Type",
      "id": "nav_type",
      "default": "list",
      "visible_if": "{{ block.settings.nav != blank }}",
      "options": [
        {
          "label": "List",
          "value": "list"
        },
        {
          "label": "Button",
          "value": "button"
        },
        {
          "label": "Both",
          "value": "both"
        }
      ]
    },
    {
      "type": "header",
      "content": "Button Options",
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_type != 'list' }}"
    },
    {
      "type": "select",
      "label": "Button Type",
      "id": "nav_button",
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_type != 'list' }}",
      "options": [
        {
          "label": "Menu Button",
          "value": "menu"
        },
        {
          "label": "Hamburger Button",
          "value": "hamburger"
        }
      ]
    },
    {
      "type": "select",
      "label": "Button Text Color",
      "id": "nav_button_color",
      "default": "white",
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_type != 'list' }}",
      "options": [
        {
          "label": "Current Color",
          "value": "current"
        },
        {
          "label": "Black",
          "value": "black"
        },
        {
          "label": "White",
          "value": "white"
        }
      ]
    },
    {
      "type": "select",
      "label": "Button Background Color",
      "id": "nav_button_bg",
      "default": "black",
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_button == 'menu' }}",
      "options": [
        {
          "label": "Black",
          "value": "black"
        },
        {
          "label": "White",
          "value": "white"
        }
      ]
    },
    {
      "type": "header",
      "content": "Navigation Options",
      "visible_if": "{{ block.settings.nav != blank }}"
    },
    {
      "type": "select",
      "label": "Navigation Text Color",
      "id": "nav_color",
      "default": "white",
      "visible_if": "{{ block.settings.nav != blank }}",
      "options": [
        {
          "label": "Current Color",
          "value": "current"
        },
        {
          "label": "Black",
          "value": "black"
        },
        {
          "label": "White",
          "value": "white"
        }
      ]
    },
    {
      "type": "select",
      "label": "Navigation Background Color",
      "id": "nav_bg_color",
      "default": "black",
      "visible_if": "{{ block.settings.nav != blank }}",
      "options": [
        {
          "label": "Black",
          "value": "black"
        },
        {
          "label": "White",
          "value": "white"
        }
      ]
    },
    {
      "type": "select",
      "label": "Text Alignment",
      "id": "nav_alignment",
      "default": "center",
      "visible_if": "{{ block.settings.nav != blank }}",
      "options": [
        {
          "label": "Left",
          "value": "left"
        },
        {
          "label": "Center",
          "value": "center"
        },
        {
          "label": "Right",
          "value": "right"
        }
      ]
    },
    {
      "type": "checkbox",
      "label": "Add Background Media",
      "id": "nav_bg_media_option",
      "default": false,
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_type != 'list' }}"
    },
    {
      "type": "image_picker",
      "label": "Background Image",
      "id": "bg_img",
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_bg_media_option == true and block.settings.nav_type != 'list' }}"
    },
    {
      "type": "video",
      "label": "Background Video",
      "id": "bg_video",
      "info": "⚠️ Image is required as a fallback for video",
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_bg_media_option == true and block.settings.bg_img != blank and block.settings.nav_type != 'list' }}"
    },
    {
      "type": "checkbox",
      "label": "Repeat Background Media",
      "id": "bg_repeat_option",
      "default": false,
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_bg_media_option == true and block.settings.bg_img != blank and block.settings.nav_type != 'list' }}"
    },
    {
      "type": "text",
      "label": "Repeat Background Media Width",
      "id": "bg_repeat_width",
      "info": "⚠️ Width can be 'px' value or '%' value",
      "default": "auto",
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_bg_media_option == true and block.settings.bg_img != blank and block.settings.bg_repeat_option == true and block.settings.nav_type != 'list' }}"
    },
    {
      "type": "range",
      "label": "Background Position (Top/Bottom)",
      "id": "bg_position_y",
      "default": 50,
      "step": 1,
      "min": 0,
      "max": 100,
      "unit": "%",
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_bg_media_option == true and block.settings.bg_img != blank and block.settings.nav_type != 'list' }}"
    },
    {
      "type": "range",
      "label": "Background Position (Left/Right)",
      "id": "bg_position_x",
      "default": 50,
      "step": 1,
      "min": 0,
      "max": 100,
      "unit": "%",
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_bg_media_option == true and block.settings.bg_img != blank and block.settings.nav_type != 'list' }}"
    },
    {
      "type": "range",
      "label": "Background Overlay Opacity",
      "id": "bg_overlay",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0,
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_bg_media_option == true and block.settings.bg_img != blank and block.settings.nav_type != 'list' }}"
    },
    {
      "type": "select",
      "id": "bg_overlay_color",
      "label": "Overlay Background Color",
      "default": "black",
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_bg_media_option == true and block.settings.bg_img != blank and block.settings.nav_type != 'list' and block.settings.bg_overlay > 0 }}",
      "options": [
        {
          "label": "White",
          "value": "white"
        },
        {
          "label": "Black",
          "value": "black"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "bg_mobile",
      "label": "Show different media on mobile",
      "default": false,
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_bg_media_option == true and block.settings.bg_img != blank and block.settings.nav_type != 'list' }}"
    },
    {
      "type": "header",
      "content": "Mobile Background Options",
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_bg_media_option == true and block.settings.bg_img != blank and block.settings.nav_type != 'list' and block.settings.bg_mobile == true }}"
    },
    {
      "type": "image_picker",
      "id": "bg_img_mobile",
      "label": "Background Image",
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_bg_media_option == true and block.settings.bg_img != blank and block.settings.nav_type != 'list' and block.settings.bg_mobile == true }}"
    },
    {
      "type": "video",
      "id": "bg_video_mobile",
      "label": "Background Video",
      "info": "⚠️ Image is required as a fallback for video",
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_bg_media_option == true and block.settings.bg_img != blank and block.settings.nav_type != 'list' and block.settings.bg_mobile == true and block.settings.bg_img_mobile != blank }}"
    },
    {
      "type": "range",
      "id": "bg_position_y_mobile",
      "label": "Image Position (Top/Bottom)",
      "default": 50,
      "step": 1,
      "min": 0,
      "max": 100,
      "unit": "%",
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_bg_media_option == true and block.settings.bg_img != blank and block.settings.nav_type != 'list' and block.settings.bg_mobile == true and block.settings.bg_img_mobile != blank }}"
    },
    {
      "type": "range",
      "id": "bg_position_x_mobile",
      "label": "Image Position (Left/Right)",
      "default": 50,
      "step": 1,
      "min": 0,
      "max": 100,
      "unit": "%",
      "visible_if": "{{ block.settings.nav != blank and block.settings.nav_bg_media_option == true and block.settings.bg_img != blank and block.settings.nav_type != 'list' and block.settings.bg_mobile == true and block.settings.bg_img_mobile != blank }}"
    }
  ],
  "blocks": [
    { "type": "heading" },
    { "type": "subheading" },
    { "type": "blurb" },
    { "type": "_icons" },
    { "type": "_cart" },
    { "type": "_account" }
  ],
  "presets": [
    {
      "name": "Navigation"
    }
  ]
}
{% endschema %}