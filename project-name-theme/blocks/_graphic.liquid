          "label": "70px",
          "value": "7"
        },
        {
          "label": "80px",
          "value": "8"
        },
        {
          "label": "90px",
          "value": "9"
        },
        {
          "label": "100px",
          "value": "10"
        }
      ]
    },
    {
      "type": "header",
      "content": "Animation Options"
    },
    {
      "type": "checkbox",
      "id": "graphic_float",
      "label": "Float the image in the center of container",
      "default": false,
      "visible_if": "{{ block.settings.graphic != blank }}"
    },
    {
      "type": "checkbox",
      "id": "graphic_rotate_animate",
      "label": "Add a rotation animation",
      "default": false,
      "visible_if": "{{ block.settings.graphic != blank }}"
    },
    {
      "type": "range",
      "id": "graphic_rotate_speed",
      "label": "Rotation Speed",
      "min": 1,
      "max": 100,
      "unit": "s",
      "step": 1,
      "default": 10,
      "visible_if": "{{ block.settings.graphic != blank and block.settings.graphic_rotate_animate == true }}"
    }
  ],
  "presets": [
    {
      "name": "Graphic"
    }
  ]
}
{% endschema %}