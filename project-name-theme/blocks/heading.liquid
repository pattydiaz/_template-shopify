{% render 'block-heading', block: block %}

{% schema %}
{
  "name": "Heading",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Lorem Ipsum",
      "label": "Heading"
    },
    {
      "type": "header",
      "content": "Formatting Options"
    },
    {
      "type": "select",
      "id":"heading_tag",
      "label": "Heading Tag",
      "default": "h2",
      "info": "⚠️ H1 should only be used once at the top of the page.",
      "options": [
        {
          "label": "H1",
          "value": "h1"
        },
        {
          "label": "H2",
          "value": "h2"
        }
      ]
    },
    {
      "type": "select",
      "id":"heading_type",
      "label": "Heading Type",
      "default": "heading-1",
      "options": [
        {
          "label": "Heading 1",
          "value": "heading-1"
        },
        {
          "label": "Heading 2",
          "value": "heading-2"
        },
        {
          "label": "Heading 3",
          "value": "heading-3"
        },
        {
          "label": "Heading 4",
          "value": "heading-4"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_color",
      "label": "Text Color",
      "options": [
        {
          "label": "White",
          "value": "white"
        },
        {
          "label": "Black",
          "value": "black"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "heading_width",
      "label": "Add custom heading width",
      "default": false
    },
    {
      "type": "range",
      "id": "heading_width_mobile",
      "default": 760,
      "label": "Heading Width (Mobile)",
      "step": 10,
      "min": 200,
      "max": 1200,
      "unit": "px",
      "visible_if": "{{ block.settings.heading_width == true }}"
    }, 
    {
      "type": "range",
      "id": "heading_width_desktop",
      "default": 760,
      "label": "Heading Width (Desktop)",
      "step": 10,
      "min": 200,
      "max": 1200,
      "unit": "px",
      "visible_if": "{{ block.settings.heading_width == true }}"
    },
    {
      "type": "header",
      "content": "Spacing Options"
    },
    {
      "type": "select",
      "id":"heading_spacing_top",
      "label": "Spacing Top",
      "default": "none",
      "options": [
        {
          "label": "None",
          "value": "none"
        },
        {
          "label": "5px",
          "value": "h"
        },
        {
          "label": "10px",
          "value": "1"
        },
        {
          "label": "15px",
          "value": "q"
        },
        {
          "label": "20px",
          "value": "2"
        },
        {
          "label": "30px",
          "value": "3"
        },
        {
          "label": "40px",
          "value": "4"
        },
        {
          "label": "50px",
          "value": "5"
        },
        {
          "label": "60px",
          "value": "6"
        },
        {
          "label": "70px",
          "value": "7"
        },
        {
          "label": "80px",
          "value": "8"
        },
        {
          "label": "90px",
          "value": "9"
        },
        {
          "label": "100px",
          "value": "10"
        }
      ]
    },
    {
      "type": "select",
      "id":"heading_spacing_bottom",
      "label": "Spacing Bottom",
      "default": "none",
      "options": [
        {
          "label": "None",
          "value": "none"
        },
        {
          "label": "5px",
          "value": "h"
        },
        {
          "label": "10px",
          "value": "1"
        },
        {
          "label": "15px",
          "value": "q"
        },
        {
          "label": "20px",
          "value": "2"
        },
        {
          "label": "30px",
          "value": "3"
        },
        {
          "label": "40px",
          "value": "4"
        },
        {
          "label": "50px",
          "value": "5"
        },
        {
          "label": "60px",
          "value": "6"
        },
        {
          "label": "70px",
          "value": "7"
        },
        {
          "label": "80px",
          "value": "8"
        },
        {
          "label": "90px",
          "value": "9"
        },
        {
          "label": "100px",
          "value": "10"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Heading"
    }
  ]
}
{% endschema %}