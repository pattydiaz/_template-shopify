{% liquid

  assign cart_spacing_left = block.settings.cart_spacing_left | prepend: ' ml-'
  assign cart_spacing_right = block.settings.cart_spacing_right | prepend: ' mr-'

  assign cart_visibility = block.settings.cart_visibility
  if cart_visibility == 'mobile'
    assign cart_visibility = ' d-ib d-none-upt'
  elsif cart_visibility == 'desktop'
    assign cart_visibility = ' d-none d-ib-upt'
  else 
    assign cart_visibility = ''
  endif
  
  assign cart_color = block.settings.cart_color
  assign cart_size = block.settings.cart_size | prepend: 'icon-'
  assign cart_count_color = block.settings.cart_count_color
  assign cart_count_bg = block.settings.cart_count_bg

%}

<div class="{{ cart_visibility }}{{ cart_spacing_left }}{{ cart_spacing_right }}" {{ block.shopify_attributes }}>
  <a id="cart-btn" href="/cart" class="icon-cart button-scale {{ cart_size }} color-{{ cart_color }}" title="Cart">
    <div class="count bg-{{ cart_count_bg }} color-{{ cart_count_color }}">{{ cart.item_count }}</div>
    <span><i></i></span>
  </a>
</div>