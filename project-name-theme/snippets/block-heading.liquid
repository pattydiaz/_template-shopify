{% liquid

assign heading = block.settings.heading

assign heading_spacing_top = block.settings.heading_spacing_top | prepend: ' pt-'
assign heading_spacing_bottom = block.settings.heading_spacing_bottom | prepend: ' pb-'
assign heading_spacing_left = block.settings.heading_spacing_left | prepend: ' ml-'
assign heading_spacing_right = block.settings.heading_spacing_right | prepend: ' mr-'

assign heading_hide = block.settings.heading_hide
assign heading_tag = block.settings.heading_tag
assign heading_type = block.settings.heading_type
assign heading_color = block.settings.heading_color
assign heading_alignment = block.settings.heading_alignment

if heading_alignment == 'inherit'
  assign heading_align = ''
else 
  assign heading_align = heading_alignment | prepend: ' text-'
endif

assign heading_width = block.settings.heading_width
assign heading_width_mobile = block.settings.heading_width_mobile | prepend: '--mw:' | append: 'px;'
assign heading_width_desktop = block.settings.heading_width_desktop | prepend: '--mw-upd:' | append: 'px;'

%}

<{{ heading_tag }} class="{% if heading_hide == true %}sr-only{% else %}{{ heading_type }} blurb{{ heading_align }}{{ heading_spacing_top }}{{ heading_spacing_bottom }}{{ heading_spacing_left }}{{ heading_spacing_right }} color-{{ heading_color }}{% if heading_width == true %} w-max{% endif %}{% endif %}"{% if heading_width == true %} style="{{ heading_width_mobile }} {{ heading_width_desktop }}"{% endif %} {{ block.shopify_attributes }}>{{ heading }}</{{ heading_tag }}>