{% liquid
  assign class = class | default: 'img-cover'
  assign img_class = img_class | default: ''
  assign attr = attr | default: 'data'
  assign size_width = size | default: 2000 | plus: 0
  assign lazy = lazy | default: true, allow_false: true
  assign critical = critical | default: false, allow_false: true
  assign pixel = 'data:image/gif;base64,R0lGODlhAQABAAAAACw='
%}

{% if request.design_mode %}
  {% assign critical = true %}
{% endif %}

{% if critical %}
  {% assign lazy_class = '' %}
  {% assign attr_prefix = '' %}
  {% assign loading = 'eager' %}
  {% assign fetchpriority = 'high' %}
  {% assign render_width = size_width | at_most: img.width %}
  {% assign src_value = img | image_url: width: render_width %}
  {% capture srcset_value %}{{ img | image_url: width: img.width }} {{ img.width }}w{% endcapture %}
{% else %}
  {% if lazy == true or lazy == 'true' %}
    {% assign lazy_class = ' lazy' %}
    {% assign attr_prefix = attr | append: '-' %}
    {% assign loading = 'lazy' %}
  {% else %}
    {% assign lazy_class = ' lazy-ignore' %}
    {% assign attr_prefix = '' %}
    {% assign loading = 'eager' %}
  {% endif %}
  {% assign fetchpriority = 'auto' %}
  {% assign render_width = size_width | at_most: img.width %}
  {% assign src_value = pixel %}

  {% capture srcset_value -%}
{% if img.width >= 150 -%}{{ img | image_url: width: 150 }} 150w,{% endif -%}
{% if img.width >= 375 -%}{{ img | image_url: width: 375 }} 375w,{% endif -%}
{% if img.width >= 750 -%}{{ img | image_url: width: 750 }} 750w,{% endif -%}
{% if img.width >= 1100 -%}{{ img | image_url: width: 1100 }} 1100w,{% endif -%}
{% if img.width >= 1500 -%}{{ img | image_url: width: 1500 }} 1500w,{% endif -%}
{% if img.width >= 1780 -%}{{ img | image_url: width: 1780 }} 1780w,{% endif -%}
{% if img.width >= 2000 -%}{{ img | image_url: width: 2000 }} 2000w,{% endif -%}
{{ img | image_url }} {{ img.width }}w
{%- endcapture %}
{% endif %}

{% if img %}
  <img
    src="{{ src_value }}"
    {{ attr_prefix }}src="{{ img | image_url: width: render_width }}"
    {{ attr_prefix }}srcset="{{ srcset_value | strip | replace: '\n','' }}"
    class="{{ class }} {{ img_class }}{{ lazy_class }}"
    decoding="async"
    loading="{{ loading }}"
    fetchpriority="{{ fetchpriority }}"
    alt="{{ img.alt | escape }}"
    width="{{ render_width }}"
    height="{{ render_width | divided_by: img.aspect_ratio }}"
  >
{% endif %}