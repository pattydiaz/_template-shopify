{% if settings.newsletter_action != blank and settings.newsletter_recaptcha_key != blank %}
  <script async src="https://www.google.com/recaptcha/api.js?render={{ settings.newsletter_recaptcha_key }}"></script>
{% else if settings.newsletter_action != blank and settings.newsletter_recaptcha_key == blank %}
  <script>alert('Recaptcha Site Key Required when using Newsletter')</script>
{% endif %}