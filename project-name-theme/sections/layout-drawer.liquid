<div id="cart-drawer" class="drawer" aria-hidden="true">

  <div class="drawer-overlay" data-drawer-close></div>

  <div class="drawer-wrapper">

    <div class="drawer-header">
      <h2 class="">Your Cart (<span class="cart-count">0</span>)</h2>
      <button class="drawer-close button-scale icon-sm" aria-label="Close cart" data-drawer-close>
        <span><i class="icon-close"></i></span>
      </button>
    </div>

    <div id="drawer-body" class="drawer-body">
      {% if cart.item_count > 0 %}
        {% render 'cart-items' %}
      {% endif %}
      <div class="drawer-empty{% if cart.item_count > 0 %} d-none{% endif %}">Your cart is empty.</div>
    </div>

    
    <div class="drawer-footer">
      <div class="drawer-subtotal">Subtotal: <span id="cart-subtotal">{{ cart.total_price | money }}</span></div>
      <p>Taxes and shipping calculated at checkout</p>
      <div class="button-group">
        <a href="{{ routes.cart_url }}" class="btn btn-primary m-1" title="View Cart">View Cart</a>
  
        <form action="{{ routes.cart_url }}" method="post">
          <button type="submit" name="checkout" class="btn btn-primary{% if cart == empty %} disabled{% endif %}">Checkout</button>
        </form>
      </div>
    </div>
    

  </div>
</div>