{% liquid

  assign section_size = section.settings.section_size | prepend: ' section-'
  assign spacing_top = section.settings.spacing_top | prepend: ' gap-tm--'
  assign spacing_bottom = section.settings.spacing_bottom | prepend: ' gap-bm--'
  assign spacing_header = section.settings.spacing_header
  
  assign container_size = section.settings.container_size | prepend: ' container-'
  assign text_position = section.settings.text_position
  assign text_alignment = section.settings.text_alignment | prepend: 'text-'

  assign hero_fixed = section.settings.hero_fixed

%}

{% if spacing_header == true and section_size contains 'none' %}
  <div class="gap-hh"></div>
{% endif %}

<div class="hero-wrapper{% if section_size contains 'none' %}{{ spacing_top }}{{ spacing_bottom }}{% else %}{{ section_size }}{% endif %}{% unless section_size contains 'none' or hero_fixed == false %} hero-animate{% endunless %}">

  {% unless section_size contains 'none' or hero_fixed == false %}
    <div class="hero-fixed">
  {% endunless %}
  
      {% render 'component-background', class: 'hero-bg', bg_settings: section.settings, critical: true %}
    
      <div class="hero-container container{{ container_size }}">
        {% if section.blocks %}
          <div class="hero-text {{ text_position }} {{ text_alignment }}">
      
            {%- for block in section.blocks -%}
              {%- case block.type -%}
    
    
                {%- when 'subheading' -%}
                {% liquid
                  assign subheading = block.settings.subheading
                  assign subheading_spacing_top = block.settings.subheading_spacing_top | prepend: ' mt-'
                  assign subheading_spacing_bottom = block.settings.subheading_spacing_bottom | prepend: ' mb-'
                %}  
                <h3 class="subheading-1{{ subheading_spacing_top }}{{ subheading_spacing_bottom }}">{{ subheading }}</h3>
    
    
                {%- when 'heading' -%}
                {% liquid
                  assign heading = block.settings.heading
                  assign heading_spacing_top = block.settings.heading_spacing_top | prepend: ' mt-'
                  assign heading_spacing_bottom = block.settings.heading_spacing_bottom | prepend: ' mb-'
                  assign heading_hide = block.settings.heading_hide
                %}
                <h1 class="{% if heading_hide %}sr-only{% else %}hero-heading heading-1{{ heading_spacing_top }}{{ heading_spacing_bottom }}{% endif %}">{{ heading }}</h1>
    
    
                {%- when 'blurb' -%}
                {% liquid
                  assign blurb = block.settings.blurb
                  assign blurb_spacing_top = block.settings.blurb_spacing_top | prepend: ' mt-'
                  assign blurb_spacing_bottom = block.settings.blurb_spacing_bottom | prepend: ' mb-'
                  assign blurb_width_mobile = block.settings.blurb_width_mobile | prepend: '--mw:' | append: 'px;'
                  assign blurb_width_desktop = block.settings.blurb_width_desktop | prepend: '--mw-upd:' | append: 'px;'
                %}
                <div class="contents w-100 w-max{% if text_alignment contains 'center' %} mx-auto{% endif %}{{ blurb_spacing_top }}{{ blurb_spacing_bottom }}" style="{{ blurb_width_mobile }} {{ blurb_width_desktop }}">{{ blurb }}</div>
    
    
                {%- when 'button' -%}
                {% liquid
                  assign button_spacing_top = block.settings.button_spacing_top | prepend: ' mt-'
                  assign button_spacing_bottom = block.settings.button_spacing_bottom | prepend: ' mb-'
                  assign button_url = block.settings.button_url
                  assign button_text = block.settings.button_text
                %}
                <div class="cta{{ button_spacing_top }}{{ button_spacing_bottom }}">
                  <a href="{{ button_url }}" class="btn btn-primary" title="{{ button_text }}"{% if button_url contains 'http://' or button_url contains 'https://' %} target="_blank" rel="nofollow"{% endif %}>{{ button_text }}</a>
                </div>


                {%- when 'logo' -%}
                {% liquid
                  assign logo = block.settings.logo
                  assign logo_spacing_top = block.settings.logo_spacing_top | prepend: ' mt-'
                  assign logo_spacing_bottom = block.settings.logo_spacing_bottom | prepend: ' mb-'
                  assign logo_width_mobile = block.settings.logo_width_mobile | prepend: '--mw:' | append: 'px;'
                  assign logo_width_desktop = block.settings.logo_width_desktop | prepend: '--mw-upd:' | append: 'px;'
                %}
                <div class="hero-heading hero-logo w-100 w-max{% if text_alignment contains 'center' %} mx-auto{% endif %}{{ logo_spacing_top }}{{ logo_spacing_bottom }}" style="{{ logo_width_mobile }} {{ logo_width_desktop }}">
                  {% render 'component-image', img: logo, class: 'img-contain', size: 150, critical: true %}
                </div>
    
    
              {%- endcase -%}
            {%- endfor -%}
            
          </div>
        {% endif %}
      </div>

  {% unless section_size contains 'none' or hero_fixed == false %}
    </div>
  {% endunless %}

</div>

