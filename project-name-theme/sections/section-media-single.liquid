{% liquid

  assign id = section.settings.id
  if id != blank
    assign id = id | downcase | replace: " ", "-" | prepend: 'id="' | append: '" '
  else
    assign id = ''
  endif

  assign spacing_top = section.settings.spacing_top | prepend: ' gap-tm--'
  assign spacing_bottom = section.settings.spacing_bottom | prepend: ' gap-bm--'
  assign spacing_header = section.settings.spacing_header

  assign animated = section.settings.animated
  assign animation = ''
  if animated == true
    assign animation = ' animated animated-group animate-up-in'
  endif
  
  assign container_size = section.settings.container_size | prepend: ' container-'
  assign bg_color = section.settings.bg_color

  assign media_image = section.settings.media_image
  assign media_video = section.settings.media_video
  assign media_ratio = section.settings.media_ratio
  assign media_animate = section.settings.media_animate

  assign media_split = section.settings.media_split
  assign media_image_2 = section.settings.media_image_2
  assign media_video_2 = section.settings.media_video_2

%}


<div {{ id }}class="media-wrapper{{ spacing_top }}{{ spacing_bottom }} bg-{{ bg_color }}">

  {% if spacing_header == true %}
    <div class="gap-hh"></div>
  {% endif %}
    
  <div class="media-container{% unless container_size contains 'none' %} container{{ container_size }}{% endunless %}{{ animation }}">
    <div class="ratio ratio-{{ media_ratio }}"{% unless media_image %} style="background-color: hsl(from var(--{{ bg_color }}) h s calc(l - 5));"{% endunless %}>

      {% unless request.design_mode or media_animate == false %}
        <div class="parallax parallax-item parallax-zoom" data-percent="-25">
      {% endunless %}

        {% if media_split and media_image_2 != blank %}
          <div class="media-split d-flex float--cover">
            <div class="media-split-column pos-relative">
        {% endif %}

            {% render 'component-image', img: media_image, lazy: true %}
            {% if media_image and media_video %}
              <div class="video-cover">
                {% render 'component-video', video: media_video, poster: media_image, lazy: true %}
              </div>
            {% endif %}

        {% if media_split and media_image_2 != blank %}
            </div>
            <div class="media-split-column pos-relative">
              {% render 'component-image', img: media_image_2, lazy: true %}
              {% if media_image and media_video %}
                <div class="video-cover">
                  {% render 'component-video', video: media_video_2, poster: media_image, lazy: true %}
                </div>
              {% endif %}
            </div>
          </div>
        {% endif %}

      {% unless request.design_mode or media_animate == false %}
        </div>
      {% endunless %}

      {% if section.blocks.size > 0 %}       
        <div class="float--center w-100 text-center px-q z-5">
          {% content_for 'blocks' %}
        </div>
      {% endif %}

    </div>
  </div>

</div>

